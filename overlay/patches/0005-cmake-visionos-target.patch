+# Device family 7 = Vision. The visionOS plist drops LSRequiresIPhoneOS (an
+# iOS-only key) and adds NSLocalNetworkUsageDescription, without which libjuice's
+# ICE host-candidate gathering — i.e. LAN co-op — fails silently.
+if(SM64_VISIONOS)
+    set(SM64_DEVICE_FAMILY "7")
+    if(NOT SM64_VISIONOS_PLIST)
+        message(FATAL_ERROR "SM64_VISIONOS_PLIST is required for visionOS builds")
