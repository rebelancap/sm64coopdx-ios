-# iOS frameworks
+# Archive/export needs the app INSTALLED into the .xcarchive. CMake emits
+# INSTALL_PATH = "" for every target, so `xcodebuild archive` runs the install
+# action, copies the app nowhere, and produces an archive with an EMPTY
+# Products/ and no ApplicationProperties in its Info.plist. -exportArchive then
+# fails with the genuinely unhelpful
+#     exportOptionsPlist error for key "method" expected one {} but found debugging
+# — "one {}" being an EMPTY set of valid distribution methods, because Xcode
+# cannot classify an archive that contains no application. It reads like the
+# export method is wrong; the method is fine and the archive is empty (M-28).
+#
+# visionOS-gated so the iOS target's generated project stays bit-for-bit
+# unchanged, and set as TARGET properties because CMake's own target-level
+# INSTALL_PATH = "" would otherwise beat a project-level cache attribute — the
+# same precedence trap as DEVELOPMENT_TEAM above.
+if(SM64_VISIONOS)
+    set_target_properties(sm64coopdx PROPERTIES
+        XCODE_ATTRIBUTE_INSTALL_PATH "$(LOCAL_APPS_DIR)"
+        XCODE_ATTRIBUTE_SKIP_INSTALL "NO"
+    )
+endif()
+
+# Frameworks. OpenGLES exists in the xrOS SDK as a .tbd but every API in it is
+# marked unavailable (M-1), so visionOS must not link it.
+if(NOT SM64_VISIONOS)
+    target_link_libraries(sm64coopdx "-framework OpenGLES")
+endif()
+
 target_link_libraries(sm64coopdx
-    "-framework OpenGLES"
