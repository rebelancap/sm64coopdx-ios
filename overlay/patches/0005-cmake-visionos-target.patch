@@ -189,6 +239,38 @@
     message(STATUS "SDL2 iOS gamepad fix patch already applied or not needed")
 endif()
 
+# SDL 2.32.10 has zero visionOS awareness: its UIKit backend leans on
+# UIScreen/status-bar APIs the xrOS SDK marks unavailable. This patch (ported
+# from the Shipwright visionOS bring-up) supplies UIScreen-free display modes, a
+# scene-glued window, the 90->120Hz display link, the drawable resize debounce
+# and the launch-once guard. It composes with the fork's iOS gamepad fix in
+# either order (verified both directions on this exact tree). Applied through the
+# fork's own git-apply mechanism above.
+if(SM64_VISIONOS)
+    if(NOT SM64_SDL2_VISIONOS_PATCH)
+        message(FATAL_ERROR "SM64_SDL2_VISIONOS_PATCH is required for visionOS builds")
+    endif()
+    execute_process(
+        COMMAND git apply --check ${SM64_SDL2_VISIONOS_PATCH}
+        WORKING_DIRECTORY ${GAME_ROOT}/lib/SDL2-source
+        RESULT_VARIABLE VISIONOS_PATCH_CHECK
+        ERROR_QUIET
+    )
+    if(VISIONOS_PATCH_CHECK EQUAL 0)
+        execute_process(
+            COMMAND git apply ${SM64_SDL2_VISIONOS_PATCH}
+            WORKING_DIRECTORY ${GAME_ROOT}/lib/SDL2-source
+            RESULT_VARIABLE VISIONOS_PATCH_APPLY
+        )
+        if(NOT VISIONOS_PATCH_APPLY EQUAL 0)
+            message(FATAL_ERROR "SDL2 visionOS compat patch failed to apply")
+        endif()
+        message(STATUS "Applied SDL2 visionOS compat patch")
+    else()
+        message(STATUS "SDL2 visionOS compat patch already applied or not needed")
+    endif()
+endif()
+
 add_subdirectory(${GAME_ROOT}/lib/SDL2-source SDL2 EXCLUDE_FROM_ALL)
 include_directories(${GAME_ROOT}/lib/SDL2-source/include)
 
