     CAPI_SDL2=1
@@ -41,6 +63,19 @@
     JUICE_STATIC
 )
 
+# ---- Renderer selection ----
+# iOS renders through OpenGL ES. visionOS cannot: the xrOS SDK marks EVERY GL
+# entry point unavailable (not just EAGLContext — glGetIntegerv et al too), so
+# the Metal backend is mandatory and GL is compiled out entirely rather than
+# merely left unused. TARGET_IOS above stays defined for visionOS on purpose:
+# it is this fork's own define (not TargetConditionals' TARGET_OS_IOS, which is
+# 0 on xros) and it carries platform.c's Documents/bundle-root semantics.
+if(SM64_VISIONOS)
+    add_compile_definitions(RAPI_METAL=1 ENABLE_METAL_BACKEND=1 SM64_NO_OPENGL=1)
+else()
+    add_compile_definitions(USE_GLES RAPI_GL=1)
+endif()
+
 # ---- Compiler flags ----
 add_compile_options(
     -fsigned-char
@@ -102,6 +137,10 @@
 list(FILTER SRC_C_FILES EXCLUDE REGEX "src/pc/gfx/gfx_sdl1\\.")
 list(FILTER SRC_C_FILES EXCLUDE REGEX "src/pc/audio/audio_sdl1\\.")
 list(FILTER SRC_C_FILES EXCLUDE REGEX "src/pc/controller/controller_sdl1\\.")
+# visionOS: gfx_opengl.c cannot compile against the xrOS SDK at all.
+if(SM64_VISIONOS)
+    list(FILTER SRC_C_FILES EXCLUDE REGEX "src/pc/gfx/gfx_opengl\\.c$")
+endif()
 # .inc.c files are #included by other files, not compiled standalone
 list(FILTER SRC_C_FILES EXCLUDE REGEX "\\.inc\\.c$")
 
